{
  "version": 1,
  "name": "image-classifier",
  "description": "Sequential experiment: first achieve convergence, then optimize accuracy",
  "created_at": "2026-03-16T10:00:00Z",
  "metric": {
    "primary": "val_loss",
    "direction": "lower",
    "floors": {},
    "phases": [
      {
        "name": "convergence",
        "metric": "val_loss",
        "direction": "lower",
        "gate": {"threshold": 2.0, "direction": "below"},
        "floors": {}
      },
      {
        "name": "optimization",
        "metric": "val_accuracy",
        "direction": "higher",
        "gate": null,
        "floors": {
          "val_loss": {"value": 2.5, "direction": "lower"}
        }
      }
    ],
    "composite_formula": null
  },
  "eval_command": "uv run train.py",
  "parse_metric": "grep '^val_loss:\\|^val_accuracy:' run.log",
  "mutable_files": ["train.py"],
  "immutable_files": ["prepare.py", "evaluate.py"],
  "read_files": ["program.md", "journal.md"],
  "write_files": ["results.tsv", "journal.md", "events.log"],
  "columns": ["commit", "val_loss", "val_accuracy", "num_params_M", "status", "description"],
  "status_values": ["baseline", "keep", "discard", "crash"],
  "time_budget_minutes": 3,
  "timeout_minutes": 7,
  "data_description": "CIFAR-100 dataset, standard train/test split",
  "data_verify_command": "ls data/cifar-100/",
  "branch_pattern": "autoresearch/{tag}",
  "context": "Image classification on CIFAR-100. Two-phase experiment: first get the model to converge reliably (val_loss below 2.0), then switch to maximizing classification accuracy while keeping loss stable.",
  "goals": "Phase 1: Minimize val_loss until below 2.0. Phase 2: Maximize val_accuracy with val_loss floor at 2.5. The agent automatically transitions when the gate condition is met."
}
